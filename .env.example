# =======================================================
# Bia · Bradesco — configuração local (copie para .env)
# =======================================================

# Motor real do agente (Claude).
# Para rodar 100% OFFLINE: deixe vazio OU use MOCK_LLM=true.
# O servidor cai no motor mock — conversa scriptada, sem internet e sem custo.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Porta do servidor Express local
PORT=3001

# true = força o motor mock mesmo com a API key presente
MOCK_LLM=false
